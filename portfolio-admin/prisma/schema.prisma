generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  excerpt   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Project {
  id          String @id @default(cuid())
  name        String
  description String
  imageUrl    String?
  link        String?
}